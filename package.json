{
  "name": "carlitos",
  "private": true,
  "workspaces": [
    "apps/*",
    "agents/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxlint": "^1.70.0",
    "turbo": "^2.9.18"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.12",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint"
  }
}
